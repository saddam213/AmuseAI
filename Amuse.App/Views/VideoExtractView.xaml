<Views:ViewBaseModel x:Class="Amuse.App.Views.VideoExtractView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Views="clr-namespace:Amuse.App.Views"
    xmlns:Controls="clr-namespace:Amuse.App.Controls">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:VideoExtractView}}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>


            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border  Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <StackPanel DockPanel.Dock="Top" IsEnabled="{Binding ExtractService.IsLoading, Converter={StaticResource InverseBoolConverter}}">

                            <!--ModelControl-->
                            <StackPanel DockPanel.Dock="Top" >
                                <Grid IsEnabled="{Binding ExtractService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                    <Controls:ModelControl
                                        x:Name="ModelControl"
                                        IsExtractorEnabled="True"
                                        Settings="{Binding Settings, Mode=OneWay}" 
                                        IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        SelectionChanged="SelectedExtractorChanged"/>
                                </Grid>
                            </StackPanel>

                        </StackPanel>

                        <!--Execute/Cancel-->
                        <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30">
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                            <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                <Button Content="Generate" Command="{Binding ExecuteCommand}" />
                            </Grid>
                        </UniformGrid>


                        <StackPanel IsEnabled="{Binding ExtractService.IsLoaded}">

                            <!--Input Video-->
                            <Border Margin="0,15,0,15"
                                VerticalAlignment="Top"
                                Style="{StaticResource VideoDropZoneStyle}"
                                Width="{Binding ActualWidth,ElementName=LeftPanelContainer}"
                                Height="{Binding ActualWidth,ElementName=LeftPanelContainer}"
                                MaxHeight="{Binding ActualWidth,ElementName=LeftPanelContainer}">
                                <CommonControls:VideoStreamElement
                                    Source="{Binding SourceVideo, Mode=TwoWay}"
                                    Volume="{Binding Settings.VolumeInput, Mode=TwoWay}"
                                    IsVolumeMute="{Binding Settings.IsVolumeInputMute, Mode=TwoWay}"
                                    IsVolumeBottom="True"
                                    IsLoadEnabled="True"
                                    IsLoadOverlayEnabled="False" 
                                    IsSaveEnabled="False" />
                            </Border>

                            <!--Options-->
                            <Controls:ExtractInputControl Pipeline="{Binding CurrentPipeline, Mode=OneWay}" Options="{Binding Options, Mode=OneWayToSource}" />

                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">
                        <Grid Margin="10,10,10,2" >
                            <CommonControls:VideoStreamElement 
                                x:Name="ResultControl"
                                SplitterVisibility="Auto"
                                SplitterPosition="Source"
                                SplitterDirection="LeftToRight"
                                Source="{Binding ResultVideo, Mode=TwoWay}" 
                                OverlaySource="{Binding CompareVideo, Mode=TwoWay}" 
                                Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                                IsLoadEnabled="False" 
                                IsLoadOverlayEnabled="False"/>
                        </Grid>
                    </Border>
                </DockPanel>

            </Grid>
        </Grid>

    </Grid>
</Views:ViewBaseModel>
