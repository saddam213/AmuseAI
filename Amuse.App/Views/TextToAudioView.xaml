<Views:ViewBaseModel x:Class="Amuse.App.Views.TextToAudioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:TextToAudioView}}}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <Grid DockPanel.Dock="Top" IsEnabled="{Binding AudioService.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding AudioService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                <Controls:ModelControl
                                    x:Name="ModelControl"
                                    IsAudioEnabled="True"
                                    ViewType="TextToAudio"
                                    Settings="{Binding Settings, Mode=OneWay}" 
                                    IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                    SelectionChanged="OnSelectedModelChanged"/>
                            </Grid>
                        </Grid>

                        <!--Execute/Cancel-->
                        <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30">
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                            <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                <Button Content="Generate" Command="{Binding ExecuteCommand}" />
                            </Grid>
                        </UniformGrid>

                        <StackPanel IsEnabled="{Binding IsPipelineLoaded}">

                            <!--Options-->
                            <StackPanel DockPanel.Dock="Top" IsEnabled="{Binding AudioService.IsLoaded}">
                                <UniformGrid Columns="2" Margin="0,4,0,0" >
                                    <StackPanel Margin="0,0,2,0">
                                        <TextBlock Text="Voice Style" Style="{StaticResource FieldTextBlockStyle}" />
                                        <ComboBox ItemsSource="{Binding CurrentPipeline.AudioModel.Prefixes}" SelectedItem="{Binding Options.VoiceStyle}" />
                                    </StackPanel>
                                    <StackPanel Margin="2,0,0,0">
                                        <TextBlock Text="Seed" Style="{StaticResource FieldTextBlockStyle}" />
                                        <Controls:SeedControl Seed="{Binding Options.Seed}"/>
                                    </StackPanel>
                                </UniformGrid>
                                <StackPanel Margin="0,4,0,0" >
                                    <CommonControls:SliderControl Value="{Binding Options.Steps}" Text="Steps" Minimum="1" Maximum="100" TickFrequency="1" />
                                </StackPanel>
                                <StackPanel Margin="0,4,0,0" >
                                    <CommonControls:SliderControl Value="{Binding Options.Speed}" Text="Speed" Minimum="0.5" Maximum="5" TickFrequency="0.01" ValuePostFix="x" ValueFormat="N1"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />

            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--Output-->
                        <Grid Margin="10,10,10,2" >

                            <DockPanel Margin="0,3,0,0" >
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Audio Result" Style="{StaticResource FieldTextBlockStyle}" />
                                    <CommonControls:AudioElement 
                                            Source="{Binding ResultAudio, Mode=TwoWay}" 
                                            Configuration="{Binding Settings}" 
                                            IsLoadEnabled="False" 
                                            Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                            IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                                            IsReplayEnabled="False" />
                                </StackPanel>

                                <DockPanel Margin="0,10,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Text Input" Style="{StaticResource FieldTextBlockStyle}" />
                                    <Border Style="{StaticResource TextDropZoneStyle}">
                                        <CommonControls:TextElement TextSource="{Binding SourceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Border>
                                </DockPanel>
                            </DockPanel>

                        </Grid>
                    </Border>

                </DockPanel>

            </Grid>
        </Grid>
    </Grid>
</Views:ViewBaseModel>
