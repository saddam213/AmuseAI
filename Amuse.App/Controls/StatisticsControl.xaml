<UserControl x:Class="Amuse.App.Controls.StatisticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
             Name="UI" >
    <DockPanel DataContext="{Binding ElementName=UI}">
        <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="0,0,0,2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Statistics.IterationsPerSecond, StringFormat={}{0:N2}}" />
                <TextBlock Text=" it/s" Style="{StaticResource FieldTextBlockStyle}" Margin="0,1,0,0"/>
                <TextBlock Text="  |  " Style="{StaticResource FieldTextBlockStyle}" Margin="0,0,0,0"/>
                <TextBlock Text="{Binding Statistics.SecondsPerIteration, StringFormat={}{0:N2}}" />
                <TextBlock Text=" s/it" Style="{StaticResource FieldTextBlockStyle}" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Elapsed: " Style="{StaticResource FieldTextBlockStyle}" Margin="0,1,0,0"/>
                <TextBlock DockPanel.Dock="Top" Text="{Binding Statistics.Elapsed, FallbackValue=00:00:00:00, StringFormat={}hh\\:mm\\:ss\\.ff}" />
            </StackPanel>
        </UniformGrid>
        <CommonControls:ProgressElement Height="20" Progress="{Binding Progress}" />
    </DockPanel>
</UserControl>
