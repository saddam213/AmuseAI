<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.MediaPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        xmlns:Common="clr-namespace:Amuse.App.Common"
        Title="Media Preview"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        Icon="/Images/Icon.ico"
        MinHeight="700"
        MinWidth="1100"
        MaxHeight="700"
        MaxWidth="1100"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:MediaPreviewDialog}}}" Margin="15, 15, 15, 10">

        <Grid DockPanel.Dock="Bottom" Height="30"  Margin="0,20,0,0">
            <UniformGrid Columns="2" HorizontalAlignment="Left">
                <Button Content="Prev" Command="{Binding PrevCommand}" Width="100"/>
                <Button Content="Next" Command="{Binding NextCommand}" Width="100"/>
            </UniformGrid>
            <Button HorizontalAlignment="Right" Content="Close" Command="{Binding CancelCommand}" Width="100" IsDefault="True"/>
        </Grid>

        <DockPanel>
            <DockPanel DockPanel.Dock="Right" Width="400" >
                <ContentControl Content="{Binding HistoryCollection.CurrentItem}" />
            </DockPanel>

            <Grid>
                <CommonControls:ImageElement 
                    IsLoadEnabled="False" 
                    IsLoadOverlayEnabled="False" 
                    IsSaveOverlayEnabled="False" 
                    IsRemoveEnabled="False"
                    Source="{Binding CurrentImage}"
                    Progress="{Binding Progress}"
                    Visibility="{Binding HistoryCollection.CurrentItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image}"/>

                <CommonControls:VideoStreamElement
                    IsReplayEnabled="True"
                    IsAutoPlayEnabled="True"
                    IsLoadEnabled="False"
                    IsLoadOverlayEnabled="False" 
                    IsSaveEnabled="True" 
                    IsRemoveEnabled="False"
                    IsFrameViewerEnabled="True"
                    IsInputEnabled="True"
                    Source="{Binding CurrentVideoStream}" 
                    Progress="{Binding Progress}"
                    Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                    IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                    Visibility="{Binding HistoryCollection.CurrentItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}"/>

                <CommonControls:AudioStreamElement
                    IsReplayEnabled="True"
                    IsAutoPlayEnabled="True"
                    IsLoadEnabled="False"
                    IsSaveEnabled="True" 
                    IsRemoveEnabled="False"
                    IsInputEnabled="True"
                    Source="{Binding CurrentAudioStream}"
                    Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                    IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                    Visibility="{Binding HistoryCollection.CurrentItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}"/>

                <CommonControls:TextElement
                    IsReadOnly="True"
                    IsLoadEnabled="False"
                    IsRemoveEnabled="False"
                    TextSource="{Binding CurrentText}"
                    Visibility="{Binding HistoryCollection.CurrentItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}"/>

            </Grid>

         
        </DockPanel>

    </DockPanel>
</CommonControls:DialogControl>