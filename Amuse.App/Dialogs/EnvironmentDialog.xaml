<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.EnvironmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        mc:Ignorable="d"
        MinWidth="400"
        MaxWidth="400"
        x:Name="UI"
        Title="Environment"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding ElementName=UI}" Margin="15, 15, 15, 10">

        <!--Save / Cancel-->
        <Grid DockPanel.Dock="Bottom"  Margin="0,15,0,0">
            <UniformGrid Columns="2" Height="30" HorizontalAlignment="Right">
                <Grid IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                    <Button Content="Create" Command="{Binding CreateCommand}" Width="100" IsDefault="True" Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Update" Command="{Binding UpdateCommand}" Width="100" IsDefault="True" Visibility="{Binding IsUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Rebuild" Command="{Binding RebuildCommand}" Width="100" IsDefault="True" Visibility="{Binding IsRebuild, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100"/>
            </UniformGrid>
        </Grid>


        <!--Progress-->
        <Grid  DockPanel.Dock="Bottom">
            <CommonControls:ProgressElement  Progress="{Binding Progress}" Height="20" />
        </Grid>


        <!--Message-->
        <DockPanel>
            <CommonControls:FontAwesome DockPanel.Dock="Left" Size="50" Margin="10,10,10,10" Icon="&#xf059;" IconStyle="Light" Color="{StaticResource InfoColour}" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,50,0">
                <Grid HorizontalAlignment="Center" >
                    <TextBlock Text="Create python virtual environment?" FontSize="15" TextWrapping="Wrap" Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="Update python virtual environment?" FontSize="15" TextWrapping="Wrap" Visibility="{Binding IsUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="Rebuild python virtual environment?" FontSize="15" TextWrapping="Wrap" Visibility="{Binding IsRebuild, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
                <TextBlock Text="(This may take several minutes)" FontSize="11" TextWrapping="Wrap" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,3,0,0" />
            </StackPanel>
        </DockPanel>

    </DockPanel>
</CommonControls:DialogControl>