<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.LoraModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        mc:Ignorable="d"
        MinWidth="600"
        MaxWidth="600"
        Title="LoRA Adapter"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:LoraModelDialog}}}" Margin="15, 15, 15, 10">

        <!--Model Settings-->
        <StackPanel DockPanel.Dock="Top">

            <UniformGrid  Columns="2">
                <StackPanel Margin="0,0,2,0">
                    <TextBlock Text="Pipeline" Style="{StaticResource FieldTextBlockStyle}"/>
                    <ComboBox ItemsSource="{Binding Pipelines}" SelectedItem="{Binding LoraModel.Pipeline}" />
                </StackPanel>
                <StackPanel Margin="2,0,0,0">
                    <TextBlock Text="Model Source" Style="{StaticResource FieldTextBlockStyle}"/>
                    <ComboBox x:Name="ComboBoxSource" ItemsSource="{Binding ModelSources}" SelectedItem="{Binding LoraModel.Source}" />
                </StackPanel>
            </UniformGrid>

            <Grid Margin="0,4,0,0">
                <StackPanel Visibility="{Binding SelectedItem, ElementName=ComboBoxSource, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Folder}">
                    <TextBlock Text="Folder (diffusers)" Style="{StaticResource FieldTextBlockStyle}" />
                    <CommonControls:FilePickerTextBox FileName="{Binding SelectedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                </StackPanel>
                <StackPanel Visibility="{Binding SelectedItem, ElementName=ComboBoxSource, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=SingleFile}">
                    <TextBlock Text="Filename (safetensors)" Style="{StaticResource FieldTextBlockStyle}" />
                    <CommonControls:FilePickerTextBox FileName="{Binding SelectedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsRequired="True" Filter="Model Files|*.safetensors;" DefaultExt="safetensors"/>
                </StackPanel>
                <StackPanel Visibility="{Binding SelectedItem, ElementName=ComboBoxSource, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=HuggingFace}">
                    <TextBlock Text="HuggingFace Url" Style="{StaticResource FieldTextBlockStyle}" />
                    <TextBox Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"  />
                </StackPanel>
            </Grid>

            <StackPanel Margin="0,4,0,0" Visibility="{Binding SelectedItem, ElementName=ComboBoxSource, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=SingleFile}">
                <TextBlock Text="Weights" Style="{StaticResource FieldTextBlockStyle}"/>
                <TextBox Text="{Binding SelectedWeights, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Margin="0,4,0,0">
                <TextBlock Text="Name" Style="{StaticResource FieldTextBlockStyle}"/>
                <TextBox Text="{Binding LoraModel.Name, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

        </StackPanel>
    

        <!--Save/Cancel/Errors-->
        <DockPanel DockPanel.Dock="Bottom" Height="30" Margin="0,15,0,0">
            <UniformGrid DockPanel.Dock="Right" Columns="2" >
                <Button Content="Save" Command="{Binding SaveCommand}" Width="100" IsDefault="True"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </UniformGrid>
            <ItemsControl ItemsSource="{Binding Errors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="IndianRed" TextWrapping="Wrap" FontSize="11"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>

        <!--Trigger Words-->
        <DockPanel Margin="0,4,0,0" >
            <DockPanel DockPanel.Dock="Top">
                <Button DockPanel.Dock="Right" Command="{Binding AddTriggerCommand}" Height="22" Width="40" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <CommonControls:FontAwesome Icon="2b" IconStyle="Light" Color="{StaticResource SuccessColour}"/>
                </Button>
                <StackPanel Margin="0,0,3,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Trigger Words" Style="{StaticResource FieldTextBlockStyle}"/>
                        <TextBlock Text="(optional)" Style="{StaticResource FieldTextBlockStyle}" FontSize="9" Margin="4,0,0,2" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <TextBox Text="{Binding SelectedTrigger, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </DockPanel>
            <ListBox ItemsSource="{Binding Trigger}" SelectedItem="{Binding SelectedTrigger}" ItemContainerStyle="{StaticResource TransparentListBoxItem}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,3,0,0" Background="Transparent" MinHeight="24">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"  />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource ButtonBackgroundDisabled}" Margin="2">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Command="{Binding RemoveTriggerCommand, RelativeSource={RelativeSource AncestorType={x:Type local:LoraModelDialog}}}" CommandParameter="{Binding}" Style="{StaticResource TransparentButton}">
                                    <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                </Button>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,2,0">
                                    <TextBlock Text="{Binding}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

    </DockPanel>
</CommonControls:DialogControl>